{
  "name": "qrcode-web-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "Frontend for the self-hosted QR Code Generator",
  "license": "MIT",
  "author": "Peter Nardi",
  "repository": {
    "type": "git",
    "url": "https://github.com/geozeke/qrcode.git"
  },
  "bugs": "https://github.com/geozeke/qrcode/issues",
  "homepage": "https://geozeke.github.io/qrcode/",
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.53.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/svelte": "^5.4.2",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-plugin-svelte": "^3.5.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.7",
    "svelte-check": "^4.2.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}
